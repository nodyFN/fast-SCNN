# === Project Outputs & Structure Preservations (Ignore content, keep folder structure via .gitkeep) ===

# Dataset structures
/data/**/images/*
!/data/**/images/.gitkeep

/data/**/masks/*
!/data/**/masks/.gitkeep

# Checkpoint weights
/checkpoints/*
!/checkpoints/.gitkeep

# Visualisation graphs and curves
/training_results/*
!/training_results/.gitkeep

# TensorBoard logs
/runs/*
!/runs/.gitkeep

# Exported ONNX models
/exports/*
!/exports/.gitkeep

# Inference outputs
/inference_results/*
!/inference_results/.gitkeep

# Evaluation logs and outputs
/evaluation_results/*
!/evaluation_results/.gitkeep
